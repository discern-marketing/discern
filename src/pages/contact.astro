---
import Layout from '../layouts/Layout.astro';
import { content } from '../content';

const { cta, footer } = content;
---

<Layout title="Contact — Discern">

  <nav class="nav nav-light">
    <a href="/" class="nav-logo">discern<span class="nav-period">.</span></a>
    <div class="nav-links">
<a href="/pricing" class="nav-link">Pricing</a>
      <a href="/results" class="nav-link">Results</a>
      <a href="/contact" class="nav-link">Contact</a>
    </div>
  </nav>

  <div class="contact-intro">
    <div>
      <div class="page-intro-label">Contact</div>
      <h1 class="contact-h1">Let's talk.</h1>
      <p class="contact-intro-body">The best starting point is a free 30-minute call — no pitch, just a clear view of where your marketing stands. You'll find us in Cardiff, working with clients across the UK.</p>
    </div>
    <div class="contact-map">
      <iframe
        src="https://maps.google.com/maps?q=Cardiff+City+Centre,+CF10,+Wales&t=m&z=14&output=embed"
        width="100%"
        height="100%"
        title="Discern location — Cardiff, Wales"
        style="border:0;display:block;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>

  <div class="contact-panel">
    <h2 class="contact-panel-h2">Ways to get in touch.</h2>
    <div class="contact-panel-grid">

      <div class="contact-details">
        <div class="contact-detail-row">
          <div class="contact-detail-key">Address</div>
          <div class="contact-detail-val">Cardiff, Wales · CF10</div>
        </div>
        <div class="contact-detail-row">
          <div class="contact-detail-key">Phone</div>
          <div class="contact-detail-val">+44 XXXX XXXXXX</div>
        </div>
        <div class="contact-detail-row">
          <div class="contact-detail-key">Email</div>
          <div class="contact-detail-val">hello@discern.marketing</div>
        </div>
      </div>

      <div>
        <!-- TODO before launch: wire up form action (e.g. Formspree or similar) -->
        <form class="contact-form">
          <div class="contact-form-row">
            <div class="contact-form-group">
              <label class="contact-form-label" for="cf-name">Name</label>
              <input type="text" id="cf-name" class="contact-form-input" placeholder="Your name">
            </div>
            <div class="contact-form-group">
              <label class="contact-form-label" for="cf-company">Company</label>
              <input type="text" id="cf-company" class="contact-form-input" placeholder="Company name">
            </div>
          </div>
          <div class="contact-form-group">
            <label class="contact-form-label" for="cf-email">Email</label>
            <input type="email" id="cf-email" class="contact-form-input" placeholder="you@company.com">
          </div>
          <div class="contact-form-group">
            <label class="contact-form-label" for="cf-message">What are you working on?</label>
            <textarea id="cf-message" class="contact-form-textarea" placeholder="Tell us a bit about your business and what you're looking for help with..."></textarea>
          </div>
          <button type="submit" class="contact-form-submit">Send message</button>
        </form>
      </div>

    </div>
  </div>

  <section class="cta">
    <h2 class="cta-h2">Start with a free<br>marketing review.</h2>
    <p class="cta-sub">{cta.subheading}</p>
    <div class="cta-actions">
      <button class="cta-btn">{cta.buttonText}</button>
      <a href={`mailto:${cta.email}`} class="cta-link">{cta.email}</a>
    </div>
  </section>

  <footer class="footer">
    <span class="footer-logo">discern<span style="color:#0F6E56;">.</span></span>
    <span class="footer-text">{footer.tagline}</span>
    <span class="footer-text">{footer.email}</span>
    <a href={footer.whatsapp} target="_blank" rel="noopener" style="display:flex;align-items:center;color:#0F6E56;transition:color 0.2s;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
    </a>
    <a href={footer.linkedin} target="_blank" rel="noopener" style="display:flex;align-items:center;color:#0A66C2;transition:color 0.2s;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
  </footer>

  <section class="press">
    <p class="press-label">As seen in</p>
    <div class="press-logos">
      <div class="press-logo">
        <svg width="88" height="30" viewBox="0 0 88 30" xmlns="http://www.w3.org/2000/svg">
          <rect x="0" y="0" width="26" height="30" rx="2" fill="#aaa"/>
          <text x="13" y="21" text-anchor="middle" font-family="Arial, sans-serif" font-size="15" font-weight="700" fill="white">B</text>
          <rect x="31" y="0" width="26" height="30" rx="2" fill="#aaa"/>
          <text x="44" y="21" text-anchor="middle" font-family="Arial, sans-serif" font-size="15" font-weight="700" fill="white">B</text>
          <rect x="62" y="0" width="26" height="30" rx="2" fill="#aaa"/>
          <text x="75" y="21" text-anchor="middle" font-family="Arial, sans-serif" font-size="15" font-weight="700" fill="white">C</text>
        </svg>
      </div>
      <div class="press-logo">
        <span style="font-family:Georgia,serif;font-size:20px;color:#bbb;letter-spacing:-0.02em;">The Guardian</span>
      </div>
      <div class="press-logo">
        <span style="font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;color:#bbb;letter-spacing:-0.01em;">b2bmarketing.net</span>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-intro {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    padding: 56px 48px 48px;
    border-bottom: 0.5px solid #eee;
    align-items: start;
  }
  .contact-h1 {
    font-family: Georgia, serif;
    font-size: 52px;
    font-weight: 500;
    color: #04342C;
    line-height: 1.08;
    margin-bottom: 16px;
  }
  .contact-intro-body {
    font-size: 16px;
    color: #555;
    line-height: 1.75;
  }
  .contact-map {
    border-radius: 8px;
    overflow: hidden;
    height: 280px;
  }

  .contact-panel {
    background: #E1F5EE;
    padding: 56px 48px;
  }
  .contact-panel-h2 {
    font-family: Georgia, serif;
    font-size: 32px;
    font-weight: 500;
    color: #04342C;
    margin-bottom: 40px;
  }
  .contact-panel-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 64px;
    align-items: start;
  }

  .contact-detail-row {
    padding: 16px 0;
    border-bottom: 0.5px solid rgba(15,110,86,0.2);
  }
  .contact-detail-row:first-child {
    border-top: 0.5px solid rgba(15,110,86,0.2);
  }
  .contact-detail-key {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0F6E56;
    margin-bottom: 4px;
  }
  .contact-detail-val {
    font-size: 15px;
    color: #04342C;
    line-height: 1.5;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .contact-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .contact-form-group {
    display: flex;
    flex-direction: column;
  }
  .contact-form-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0F6E56;
    margin-bottom: 6px;
  }
  .contact-form-input {
    padding: 11px 14px;
    border: 0.5px solid rgba(15,110,86,0.3);
    border-radius: 6px;
    font-size: 14px;
    color: #04342C;
    background: #fff;
    font-family: 'DM Sans', sans-serif;
    width: 100%;
  }
  .contact-form-input::placeholder { color: #aaa; }
  .contact-form-input:focus { outline: none; border-color: #0F6E56; }
  .contact-form-textarea {
    padding: 11px 14px;
    border: 0.5px solid rgba(15,110,86,0.3);
    border-radius: 6px;
    font-size: 14px;
    color: #04342C;
    background: #fff;
    font-family: 'DM Sans', sans-serif;
    height: 130px;
    resize: vertical;
    width: 100%;
  }
  .contact-form-textarea::placeholder { color: #aaa; }
  .contact-form-textarea:focus { outline: none; border-color: #0F6E56; }
  .contact-form-submit {
    background: #0F6E56;
    color: #E1F5EE;
    padding: 13px 28px;
    border-radius: 7px;
    font-size: 14px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    align-self: flex-start;
    transition: background 0.2s;
  }
  .contact-form-submit:hover { background: #04342C; }
</style>
